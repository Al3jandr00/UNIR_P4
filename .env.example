# Proveedor OpenAI directo
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Proveedor Azure OpenAI (tiene prioridad sobre OpenAI si está configurado)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_MODEL=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# Parámetros del modelo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=350
OPENAI_TOP_P=1.0

# Activar fallback local cuando no hay credenciales configuradas (útil en tests)
AI_ALLOW_LOCAL_FALLBACK=false
